        if (limelight.hasTarget()) {
            double hubX = limelight.getTX();
            double hubY = limelight.getTL();
            double hubTY = limelight.getTY();

            
            CurrdistanceFromTarget = (targetHeight - cameraHeight) / Math.tan(Math.toRadians(cameraAngle + hubTY));
            System.out.println("Distance from target: " + distanceFromTarget); //Generate distance from AprilTag

